APP_NAME=AI Summary API

# Option A: local temporary credentials. Populate only in .env, never here.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Option B: AWS CLI/SSO profile. Do not configure both options unless needed.
# AWS_PROFILE=your-corpay-sso-profile
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Approved Bedrock foundation-model ID or inference-profile ID.
BEDROCK_MODEL_ID=replace-with-approved-bedrock-model-or-inference-profile-id

# Bedrock Guardrail used to mask PII before model inference.
BEDROCK_GUARDRAIL_ID=replace-with-guardrail-id
BEDROCK_GUARDRAIL_VERSION=1

# Optional custom/VPC Bedrock Runtime endpoint. Leave empty for the AWS default.
BEDROCK_ENDPOINT_URL=

# Boto3 uses the standard AWS credential chain. Never commit populated values.
# AWS_SESSION_TOKEN is mandatory when it was issued with temporary credentials.

LLM_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_SECONDS=1.0
LLM_RETRY_MAX_DELAY_SECONDS=8.0

LOG_SANITIZATION_DETAILS=false

# Set false when API consumers must not receive original PII-bearing content.
INCLUDE_ORIGINAL_CONTENT=true

# Set these for the approved model to enable cost estimates. Zero means unknown/not configured.
LLM_INPUT_COST_PER_MILLION_TOKENS_USD=0
LLM_OUTPUT_COST_PER_MILLION_TOKENS_USD=0
USD_TO_GBP_EXCHANGE_RATE=0.79
